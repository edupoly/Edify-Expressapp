html
    body
        h1(style={color:'red'}) Hello #{fullname}
        input(type="radio" name="staus" checked)
        label All
        input(type="radio" name="staus")
        label Processing
        input(type="radio" name="staus") 
        label Pending
        table(border=2)
            thead
                tr 
                    th Type
                    th Remarks
                    th Time
                    th Status
            each issue in issues
                tr()
                    td #{issue.issueType}
                    td #{issue.remarks}
                    td #{(new Date(issue.timeStamp)).toLocaleString()}
                    td #{issue.status}