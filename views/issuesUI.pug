html
    body
        h1 Hello #{fullname}
        table(border=2)
            thead
                tr 
                    th Type
                    th Remarks
                    th Time
                    th Status
            each issue in issues
                tr
                    td #{issue.issueType}
                    td #{issue.remarks}
                    td #{(new Date(issue.timeStamp)).toLocaleString()}
                    td #{issue.status}